{
  "name": "spendline",
  "private": true,
  "packageManager": "pnpm@10.17.1",
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @spendline/web --filter @spendline/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.28",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
